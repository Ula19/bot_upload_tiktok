# ==================== ОБЯЗАТЕЛЬНЫЕ ====================

# Токен бота (получить у @BotFather)
BOT_TOKEN=

# Telegram API (получить на https://my.telegram.org)
# нужны для Local Bot API (контейнер bot-api) — файлы > 50 МБ
API_ID=
API_HASH=

# Юзернейм бота (без @) — используется в подписи к медиа
BOT_USERNAME=your_bot_username

# ==================== БАЗА ДАННЫХ ====================

DB_HOST=postgres
DB_PORT=5432
DB_NAME=bot_4_tiktok
DB_USER=bot_4_tiktok
DB_PASSWORD=

# ==================== АДМИНЫ ====================

# Telegram ID админов через запятую
ADMIN_IDS=
ADMIN_USERNAME=admin

# ==================== ПОРТЫ ====================

# Порт Local Bot API на хосте (чтобы не конфликтовать с другими ботами)
BOT_API_PORT=8091

# ==================== COBALT API ====================

# Cobalt API — основной движок скачивания TikTok (без watermark, быстрый)
# Документация: https://github.com/imputnet/cobalt/blob/main/docs/api.md
COBALT_API_URL=http://cobalt:9000
# API-ключ (оставить пустым если Cobalt без авторизации)
COBALT_API_KEY=

# ==================== ПРОКСИ ====================

# SOCKS5 резидентный прокси для обхода блокировки TikTok по IP
# Если задан — yt-dlp будет ходить через прокси, Cobalt будет пропущен
# (Cobalt не умеет проксировать исходящие запросы)
PROXY_URL=socks5://user:pass@host:1080

# ==================== КЭШ ====================

# Кэш скачиваний в БД (дни) — не перекачиваем одно и то же видео
CACHE_TTL_DAYS=1
